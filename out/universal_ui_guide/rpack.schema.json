{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "bindings": {
      "type": "object"
    },
    "generated_at": {
      "type": "string"
    },
    "generator": {
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "type": "object"
    },
    "required_references": {
      "type": "object"
    },
    "risk_flags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "rpack_version": {
      "type": "string"
    },
    "scene": {
      "properties": {
        "heading_raw": {
          "type": "string"
        },
        "ordinal": {
          "type": "integer"
        },
        "scene_id": {
          "type": "string"
        }
      },
      "required": [
        "scene_id",
        "heading_raw",
        "ordinal"
      ],
      "type": "object"
    },
    "shots": {
      "items": {
        "required": [
          "shot_id",
          "duration_s",
          "framing",
          "beat",
          "notes",
          "risk_flags"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "source": {
      "properties": {
        "filename": {
          "type": "string"
        },
        "hash": {
          "type": "string"
        }
      },
      "required": [
        "filename",
        "hash"
      ],
      "type": "object"
    },
    "target_provider": {
      "type": "string"
    },
    "target_provider_version": {
      "type": "string"
    }
  },
  "required": [
    "rpack_version",
    "target_provider",
    "target_provider_version",
    "source",
    "generator",
    "generated_at",
    "scene",
    "shots",
    "bindings",
    "risk_flags"
  ],
  "title": "RenderPackage v0.1",
  "type": "object"
}
